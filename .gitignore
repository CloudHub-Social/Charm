dev/synapse/data/
dev/synapse/data-mas/

# Storybook build output
storybook-static/

# Playwright e2e output
/playwright-report/
/test-results/

# claude.ai/design sync — commit the durable config/notes/overrides under
# .design-sync/, ignore only the build output + verification working state.
ds-bundle/
.ds-sync/
.design-sync/sb-reference/
.design-sync/types/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# graphify code graph — built locally with `graphify update .`, not committed:
# it goes stale on every code change and oxfmt would fight the generated JSON.
graphify-out/

# Sentry snapshot capture output (see .github/workflows/sentry-snapshots.yml)
.artifacts/
