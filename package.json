{
  "name": "charm",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "prepare": "sh scripts/install-git-hooks.sh",
    "postinstall": "node scripts/install-knope.js",
    "setup:knope": "node scripts/install-knope.js",
    "knope": "knope",
    "document-change": "knope document-change",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build --mode web",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s command-test -n server,test \"http-server storybook-static -p 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docs:features:validate": "node scripts/sync-feature-docs.mjs",
    "docs:features:check": "node scripts/sync-feature-docs.mjs --check && FEATURE_DOCS_COMPARE=1 playwright test e2e/feature-docs-current.spec.ts --project=chromium",
    "docs:features:sync": "node scripts/sync-feature-docs.mjs --write",
    "knip": "knip",
    "tokens:pull": "node scripts/tokens-pull.mjs",
    "check:observability-ratchet": "node scripts/check-observability-ratchet.mjs"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@sentry/react": "^10.65.0",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/core": "^3.27.4",
    "@tiptap/extension-mention": "^3.27.4",
    "@tiptap/extension-placeholder": "^3.27.4",
    "@tiptap/pm": "^3.27.4",
    "@tiptap/react": "^3.27.4",
    "@tiptap/starter-kit": "^3.27.4",
    "@tiptap/suggestion": "^3.27.4",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "emoji-regex": "^10.6.0",
    "highlight.js": "^11.11.1",
    "html-react-parser": "^6.1.4",
    "jotai": "^2.20.1",
    "katex": "^0.17.0",
    "linkify-react": "^4.3.3",
    "linkifyjs": "^4.3.3",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-virtuoso": "^4.18.10",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "playwright": "1.61.1",
    "postcss": "^8.5.19",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "types": ".design-sync/types/ds-entry.d.ts"
}
