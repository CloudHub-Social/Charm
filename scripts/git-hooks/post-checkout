#!/bin/sh
# Auto-links node_modules and graphify-out into a freshly created worktree.
#
# git worktree add performs a checkout in the new worktree, so this shared
# post-checkout hook (hooks live in the common .git dir and apply to every
# worktree) fires there too. We only want to act on that "brand new worktree"
# case, not on every ordinary branch switch — git signals that by passing an
# all-zero previous HEAD ($1) on the initial checkout of a new worktree/clone.
prev_head="$1"
branch_checkout="$3"

case "$prev_head" in
  0000000000000000000000000000000000000000) ;;
  *) exit 0 ;;
esac
[ "$branch_checkout" = "1" ] || exit 0

worktree_root="$(git rev-parse --show-toplevel)" || exit 0
main_root="$(git worktree list --porcelain | sed -n '/^worktree /{s/^worktree //p; q;}')"
[ -n "$main_root" ] || exit 0
[ "$worktree_root" = "$main_root" ] && exit 0

cd "$worktree_root" || exit 0

if [ ! -e node_modules ] && [ ! -L node_modules ] \
   && [ -d "$main_root/node_modules" ] \
   && [ -f "$main_root/pnpm-lock.yaml" ] && [ -f pnpm-lock.yaml ] \
   && diff -q "$main_root/pnpm-lock.yaml" pnpm-lock.yaml >/dev/null 2>&1; then
  ln -s "$main_root/node_modules" node_modules
fi

if [ ! -e graphify-out ] && [ ! -L graphify-out ] && [ -d "$main_root/graphify-out" ]; then
  ln -s "$main_root/graphify-out" graphify-out
fi

exit 0
