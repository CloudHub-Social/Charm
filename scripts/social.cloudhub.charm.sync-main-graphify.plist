<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>social.cloudhub.charm.sync-main-graphify</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>__REPO_ROOT__/scripts/sync-main-graphify.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>CHARM_MAIN_WORKTREE</key>
    <string>__REPO_ROOT__</string>
    <key>PATH</key>
    <string>__HOME_DIR__/.pyenv/shims:__HOME_DIR__/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartInterval</key>
  <integer>900</integer>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/tmp/charm-sync-main-graphify.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/charm-sync-main-graphify.log</string>
</dict>
</plist>
